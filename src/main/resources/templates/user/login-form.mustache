{{> layout/header}}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card" style="overflow: hidden;">
                <div class="card-header-form">
                    <h4>로그인</h4>
                </div>
                <div class="card-body-form">
                    <form action="/login" method="post" enctype="application/x-www-form-urlencoded">
                        <div class="mb-3">
                            <label for="username" class="form-label">아이디</label>
                            <input type="text" class="form-control" id="username" name="username" placeholder="아이디를 입력하세요" required>
                        </div>
                        <div class="mb-4">
                            <label for="password" class="form-label">비밀번호</label>
                            <input type="password" class="form-control" id="password" name="password" placeholder="비밀번호를 입력하세요" required>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">로그인하기</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center" style="background-color: var(--color-bg-warm); padding: 1rem;">
                    <small style="color: var(--color-text-muted);">계정이 없으신가요? <a href="/join-form" style="font-weight: 600;">회원가입</a></small>
                </div>
            </div>
        </div>
    </div>
</div>

{{> layout/footer}}
